# Python runtime artifacts. The committed outputs under
# e2e/upstream/output/ are reference data and should stay tracked.
.venv/
e2e/smoke/__pycache__/
e2e/upstream/__pycache__/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
*.egg-info/

# DuckLake catalogs generated by tests and local smoke runs.
*.ducklake
*.ducklake.wal
e2e/benchmark/.work/
e2e/benchmark/results/*.json
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
demo_*_data/

# Each example's headless run writes a metrics JSON here per (example, catalog, storage).
.results/

# Local path-dev symlinks (e.g. `ducklake_client` -> ../ducklake-python-client); not used by CI.
.deps/

# Local secrets shared by `e2e/docker-compose.yml` and the e2e examples
# (S3_* from setup-garage.sh, DUCKLAKE_BENCHMARK_S3_* from the legacy
# benchmark, etc). Never commit. Use `e2e/.env.example` for the template
# if you want one tracked.
.env
*.env
!*.env.example
