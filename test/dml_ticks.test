# name: test/dml_ticks.test
# description: DML snapshot tick queries and stateful listen contract
# group: [test]

require ducklake_cdc

require icu

require parquet

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH 'ducklake:__TEST_DIR__/dml_ticks.ducklake' AS lake
  (DATA_PATH '__TEST_DIR__/dml_ticks_data');

statement ok
CREATE SCHEMA lake.aux;

statement ok
CREATE TABLE lake.orders(id INTEGER, status VARCHAR);

statement ok
INSERT INTO lake.orders VALUES (1, 'new'), (2, 'paid');

statement ok
CREATE TABLE lake.aux.hidden(id INTEGER);

statement ok
INSERT INTO lake.aux.hidden VALUES (10);

statement ok
SET VARIABLE dml_ticks_head = (
  SELECT max(snapshot_id) FROM __ducklake_metadata_lake.ducklake_snapshot
);

query I
SELECT count(*) >= 1
FROM cdc_dml_ticks_query('lake', 0, table_names := ['orders']);
----
true

query TT
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM cdc_dml_ticks_query('lake', 0, table_names := ['orders']));
----
snapshot_id	BIGINT
snapshot_time	TIMESTAMP WITH TIME ZONE
schema_version	BIGINT
table_ids	BIGINT[]

query I
SELECT count(*) >= 1
FROM cdc_dml_ticks_query('lake', 0, table_names := ['aux.hidden']);
----
true

query I
SELECT count(*) = 0
FROM cdc_dml_ticks_query('lake', 0, table_names := ['orders'])
WHERE list_contains(table_ids, (
  SELECT t.table_id
  FROM __ducklake_metadata_lake.ducklake_table t
  JOIN __ducklake_metadata_lake.ducklake_schema s USING (schema_id)
  WHERE s.schema_name = 'aux'
    AND t.table_name = 'hidden'
    AND t.begin_snapshot <= getvariable('dml_ticks_head')
    AND (t.end_snapshot IS NULL OR t.end_snapshot > getvariable('dml_ticks_head'))
));
----
true

statement ok
SELECT * FROM cdc_dml_consumer_create(
  'lake',
  'listen_backlog',
  table_name := 'orders',
  start_at := 'now'
);

statement ok
SELECT * FROM cdc_consumer_reset('lake', 'listen_backlog', to_snapshot := 'beginning');

query I
SELECT count(*) >= 1
FROM cdc_dml_ticks_listen('lake', 'listen_backlog', timeout_ms := 0, max_snapshots := 1000);
----
true

query TT
SELECT column_name, column_type
FROM (
  DESCRIBE SELECT * FROM cdc_dml_ticks_listen(
    'lake',
    'listen_backlog',
    timeout_ms := 0,
    "coalesce" := false
  )
);
----
consumer_name	VARCHAR
start_snapshot	BIGINT
end_snapshot	BIGINT
snapshot_id	BIGINT
snapshot_time	TIMESTAMP WITH TIME ZONE
schema_version	BIGINT
table_ids	BIGINT[]
