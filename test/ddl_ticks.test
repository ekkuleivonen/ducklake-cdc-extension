# name: test/ddl_ticks.test
# description: DDL snapshot tick query contract
# group: [test]

require ducklake_cdc

require icu

require parquet

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl_ticks.ducklake' AS lake
  (DATA_PATH '__TEST_DIR__/ddl_ticks_data');

statement ok
CREATE SCHEMA lake.aux;

statement ok
CREATE TABLE lake.orders(id INTEGER, status VARCHAR);

statement ok
CREATE TABLE lake.aux.hidden(id INTEGER);

query I
SELECT count(*) >= 1
FROM cdc_ddl_ticks_query('lake', 0);
----
true

query TT
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM cdc_ddl_ticks_query('lake', 0));
----
snapshot_id	BIGINT
snapshot_time	TIMESTAMP WITH TIME ZONE
schema_version	BIGINT
changes_made	VARCHAR
schema_ids	BIGINT[]
table_ids	BIGINT[]
change_count	BIGINT

query I
SELECT count(*) >= 1
FROM cdc_ddl_ticks_query('lake', 0, schemas := ['aux']);
----
true
