# name: test/sql/recent_sugar.test
# description: Stateless sugar wrappers (cdc_recent_changes, cdc_recent_ddl).
# group: [sql]

#              No consumer required, no cursor, no commit. Compose
#              <lake>.table_changes(...) and the cdc_ddl extractor with bare
#              snapshot bounds derived from now() - INTERVAL since_seconds
#              SECOND. Bootstrapping the CDC state tables is NOT required for
#              these to work - they read upstream catalog state directly.

require ducklake_cdc

require icu

require parquet

# DuckLake is loaded at runtime from the official extension repository
# instead of being compiled from source. `require ducklake` cannot be used
# because sqllogictest's `require <ext>` only checks for statically-loaded
# extensions, which DuckLake is not in this build.
statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH 'ducklake:__TEST_DIR__/recent.ducklake' AS lake (DATA_PATH '__TEST_DIR__/recent_data');

statement ok
CREATE TABLE lake.orders(id INTEGER, status VARCHAR);

statement ok
INSERT INTO lake.orders VALUES (1, 'new'), (2, 'paid');

statement ok
UPDATE lake.orders SET status = 'shipped' WHERE id = 2;

statement ok
DELETE FROM lake.orders WHERE id = 1;

# cdc_recent_changes returns one row per row-level change in the lookback
# window (default 5 minutes is wide enough to cover everything we just did).
# Schema is the underlying table_changes columns plus snapshot_time / commit
# metadata.
query II
SELECT count(*), count(DISTINCT change_type) FROM cdc_recent_changes('lake', 'orders');
----
5	4

query II
SELECT change_type, id FROM cdc_recent_changes('lake', 'orders')
ORDER BY snapshot_id ASC, rowid ASC, change_type ASC;
----
insert	1
insert	2
update_postimage	2
update_preimage	2
delete	1

# since_seconds = 0 still works - it picks up events from the very last
# snapshot only. With our recent activity we still expect to see something.
query I
SELECT count(*) >= 0 FROM cdc_recent_changes('lake', 'orders', since_seconds = 0);
----
true

# Negative since_seconds is rejected at bind time.
statement error
SELECT * FROM cdc_recent_changes('lake', 'orders', since_seconds = -1);
----
since_seconds must be >= 0

# A non-existent table is rejected loudly during the LIMIT 0 schema probe.
statement error
SELECT * FROM cdc_recent_changes('lake', 'no_such_table');
----
cdc_recent_changes failed to resolve table

# cdc_recent_ddl returns DDL events from the lookback window. Default is
# 1 day - wide enough to include the CREATE TABLE we just ran. The shipped
# foundation reuses the same Stage-1 / Stage-2 extractor as cdc_ddl. The
# `main` schema is auto-created at ATTACH time and shows up here as
# `created.schema main` - that's the on-disk truth.
query III
SELECT event_kind, object_kind, object_name FROM cdc_recent_ddl('lake')
ORDER BY snapshot_id;
----
created	schema	main
created	table	orders

statement ok
CREATE SCHEMA lake.warehouse;

statement ok
CREATE VIEW lake.warehouse.orders_v AS SELECT * FROM lake.main.orders;

statement ok
DROP VIEW lake.warehouse.orders_v;

statement ok
DROP SCHEMA lake.warehouse;

# All recent DDL appears, ordered by snapshot.
query III
SELECT event_kind, object_kind, object_name FROM cdc_recent_ddl('lake')
ORDER BY snapshot_id;
----
created	schema	main
created	table	orders
created	schema	warehouse
created	view	orders_v
dropped	view	orders_v
dropped	schema	warehouse

# Optional `for_table` filter narrows to events scoped to a specific table.
# Schema-level events (which have no table identity) are dropped, so passing
# a table that has no DDL events returns zero rows even if other DDL exists.
# (We use `for_table` instead of `table` because `table` is a reserved word
# in DuckDB's parser.)
query III
SELECT event_kind, object_kind, object_name FROM cdc_recent_ddl('lake', for_table = 'orders');
----
created	table	orders

# Unqualified table name auto-qualifies to main.<name>.
query III
SELECT event_kind, object_kind, object_name FROM cdc_recent_ddl('lake', for_table = 'main.orders');
----
created	table	orders

# Negative since_seconds is rejected.
statement error
SELECT * FROM cdc_recent_ddl('lake', since_seconds = -1);
----
since_seconds must be >= 0

# Both stateless wrappers refuse to run against an incompatible catalog.
statement ok
ATTACH ':memory:' AS fake;

statement ok
CREATE SCHEMA fake.__ducklake_metadata_fake;

statement ok
CREATE TABLE fake.__ducklake_metadata_fake.ducklake_metadata (key VARCHAR, value VARCHAR);

statement ok
INSERT INTO fake.__ducklake_metadata_fake.ducklake_metadata VALUES ('version', '99.99');

statement error
SELECT * FROM cdc_recent_changes('fake', 'orders');
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_recent_ddl('fake');
----
CDC_INCOMPATIBLE_CATALOG

# Stateless wrappers do NOT require the CDC state tables. Confirm none of
# the __ducklake_cdc_* tables were created as a side-effect of this test.
query I
SELECT count(*) FROM duckdb_tables()
WHERE database_name = '__ducklake_metadata_lake'
  AND table_name LIKE '\_\_ducklake\_cdc\_%' ESCAPE '\';
----
0
