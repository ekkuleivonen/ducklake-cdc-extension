# name: test/sql/consumer_state.test
# description: lazy consumer-state bootstrap plus cdc_consumer_create/list
# group: [sql]

require ducklake_cdc

require icu

require parquet

# DuckLake is loaded at runtime from the official extension repository
# instead of being compiled from source. `require ducklake` cannot be used
# because sqllogictest's `require <ext>` only checks for statically-loaded
# extensions, which DuckLake is not in this build.
statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH 'ducklake:__TEST_DIR__/consumer_state.ducklake' AS lake (DATA_PATH '__TEST_DIR__/consumer_state_data');

# Fresh DuckLake catalog: no cdc state tables before the first lifecycle call.
query I
SELECT count(*) FROM duckdb_tables()
WHERE database_name = '__ducklake_metadata_lake'
  AND schema_name = '__ducklake_cdc'
  AND table_name IN ('__ducklake_cdc_consumers', '__ducklake_cdc_audit', '__ducklake_cdc_dlq');
----
0

# Bootstrap fires on first create; the function returns a small useful row.
statement ok
SET VARIABLE snapshots_before_consumer_create = (SELECT max(snapshot_id) FROM __ducklake_metadata_lake.ducklake_snapshot);

query II
SELECT consumer_name, consumer_id FROM cdc_consumer_create('lake', 'demo');
----
demo	1

# Consumer-state bootstrap lives outside DuckLake-managed tables and must not
# create a DuckLake snapshot.
query I
SELECT max(snapshot_id) = getvariable('snapshots_before_consumer_create')
FROM __ducklake_metadata_lake.ducklake_snapshot;
----
true

# All three catalog-resident state tables now exist.
query I
SELECT count(*) FROM duckdb_tables()
WHERE database_name = '__ducklake_metadata_lake'
  AND schema_name = '__ducklake_cdc'
  AND table_name IN ('__ducklake_cdc_consumers', '__ducklake_cdc_audit', '__ducklake_cdc_dlq');
----
3

# Listing returns rows in creation order.
query II
SELECT consumer_name, consumer_id FROM cdc_consumer_list('lake');
----
demo	1

# The operation and its audit row are created together.
query III
SELECT action, consumer_name, consumer_id FROM __ducklake_metadata_lake.__ducklake_cdc.__ducklake_cdc_audit;
----
consumer_create	demo	1

# Bootstrap is idempotent; the second consumer gets the next integer id.
query II
SELECT consumer_name, consumer_id FROM cdc_consumer_create('lake', 'mirror');
----
mirror	2

query II
SELECT consumer_name, consumer_id FROM cdc_consumer_list('lake');
----
demo	1
mirror	2

# Duplicate names are rejected even though DuckLake does not yet support
# PRIMARY KEY/UNIQUE constraints on regular DuckLake tables.
statement error
SELECT * FROM cdc_consumer_create('lake', 'demo');
----
consumer 'demo' already exists

# start_at = 'beginning' resolves to the oldest DuckLake snapshot.
statement ok
SELECT * FROM cdc_consumer_create('lake', 'from_beginning', start_at = 'beginning');

query I
SELECT last_committed_snapshot FROM cdc_consumer_list('lake') WHERE consumer_name = 'from_beginning';
----
0

# A brand-new consumer sees an empty window. Internal CDC state-table
# writes are filtered out of the window calculation.
query III
SELECT start_snapshot, end_snapshot, has_changes FROM cdc_window('lake', 'from_beginning');
----
1	0	false

# Re-calling from the same connection is idempotent until cdc_commit lands.
query III
SELECT start_snapshot, end_snapshot, has_changes FROM cdc_window('lake', 'from_beginning');
----
1	0	false

statement ok
CREATE TABLE lake.window_probe(id INTEGER);

statement ok
INSERT INTO lake.window_probe VALUES (1);

query I
SELECT schema_changes_pending FROM cdc_window('lake', 'from_beginning');
----
true

statement ok
SELECT * FROM cdc_consumer_create('lake', 'dml_window');

statement ok
INSERT INTO lake.window_probe VALUES (2);

query I
SELECT has_changes FROM cdc_window('lake', 'dml_window');
----
true

query I
SELECT snapshot_id IS NOT NULL FROM cdc_wait('lake', 'dml_window', timeout_ms = 0);
----
true

query I
SELECT heartbeat_extended FROM cdc_consumer_heartbeat('lake', 'dml_window');
----
true

statement ok
SET VARIABLE dml_window_end_snapshot = (SELECT end_snapshot FROM cdc_window('lake', 'dml_window'));

query III
SELECT consumer_name,
       committed_snapshot = getvariable('dml_window_end_snapshot'),
       schema_version IS NOT NULL
FROM cdc_commit('lake', 'dml_window', getvariable('dml_window_end_snapshot'));
----
dml_window	1	1

query I
SELECT last_committed_snapshot = getvariable('dml_window_end_snapshot')
FROM cdc_consumer_list('lake') WHERE consumer_name = 'dml_window';
----
true

query III
SELECT start_snapshot = getvariable('dml_window_end_snapshot') + 1,
       end_snapshot = getvariable('dml_window_end_snapshot'),
       has_changes
FROM cdc_window('lake', 'dml_window');
----
true	true	false

query I
SELECT snapshot_id IS NULL FROM cdc_wait('lake', 'dml_window', timeout_ms = 0);
----
true

statement ok
INSERT INTO lake.window_probe VALUES (3);

query I
SELECT has_changes FROM cdc_window('lake', 'dml_window');
----
true

statement error
SELECT * FROM cdc_commit('lake', 'dml_window', 0);
----
behind consumer 'dml_window' cursor

statement ok
SELECT * FROM cdc_consumer_create('lake', 'commit_without_window');

statement error
SELECT * FROM cdc_commit('lake', 'commit_without_window', 0);
----
CDC_BUSY

statement error
SELECT * FROM cdc_consumer_heartbeat('lake', 'commit_without_window');
----
CDC_BUSY

statement error
SELECT * FROM cdc_consumer_heartbeat('lake', 'missing');
----
consumer 'missing' does not exist

statement error
SELECT * FROM cdc_commit('lake', 'missing', 0);
----
consumer 'missing' does not exist

statement error
SELECT * FROM cdc_window('lake', 'from_beginning', max_snapshots = 1001);
----
CDC_MAX_SNAPSHOTS_EXCEEDED

statement error
SELECT * FROM cdc_window('lake', 'missing');
----
consumer 'missing' does not exist

statement error
SELECT * FROM cdc_wait('lake', 'missing', timeout_ms = 0);
----
consumer 'missing' does not exist

# Reset with omitted target follows the roadmap default: oldest available.
query II
SELECT consumer_name, new_snapshot FROM cdc_consumer_reset('lake', 'demo');
----
demo	0

# Reset can also target the current snapshot.
query I
SELECT new_snapshot = (SELECT max(snapshot_id) FROM __ducklake_metadata_lake.ducklake_snapshot)
FROM cdc_consumer_reset('lake', 'demo', to_snapshot = 'now');
----
true

# Explicit BIGINT reset target is validated against ducklake_snapshot.
query II
SELECT consumer_name, new_snapshot FROM cdc_consumer_reset('lake', 'mirror', to_snapshot = '0');
----
mirror	0

statement error
SELECT * FROM cdc_consumer_reset('lake', 'missing');
----
consumer 'missing' does not exist

# Reset writes audit rows and updates list output.
query III
SELECT action, consumer_name, consumer_id FROM __ducklake_metadata_lake.__ducklake_cdc.__ducklake_cdc_audit
WHERE action = 'consumer_reset'
ORDER BY audit_id;
----
consumer_reset	demo	1
consumer_reset	demo	1
consumer_reset	mirror	2

# Drop deletes the consumer row but leaves a durable audit entry.
query II
SELECT consumer_name, consumer_id FROM cdc_consumer_drop('lake', 'mirror');
----
mirror	2

query I
SELECT count(*) FROM cdc_consumer_list('lake') WHERE consumer_name = 'mirror';
----
0

query III
SELECT action, consumer_name, consumer_id FROM __ducklake_metadata_lake.__ducklake_cdc.__ducklake_cdc_audit
WHERE action = 'consumer_drop'
ORDER BY audit_id;
----
consumer_drop	mirror	2

statement error
SELECT * FROM cdc_consumer_drop('lake', 'missing');
----
consumer 'missing' does not exist

statement ok
SELECT * FROM cdc_consumer_create('lake', 'leased');

statement ok
UPDATE __ducklake_metadata_lake.__ducklake_cdc.__ducklake_cdc_consumers
SET owner_token = '00000000-0000-0000-0000-000000000001'::UUID,
    owner_acquired_at = now(),
    owner_heartbeat_at = now()
WHERE consumer_name = 'leased';

statement error
SELECT * FROM cdc_window('lake', 'leased');
----
CDC_BUSY

query III
SELECT consumer_name, consumer_id, previous_token
FROM cdc_consumer_force_release('lake', 'leased');
----
leased	6	00000000-0000-0000-0000-000000000001

query III
SELECT owner_token IS NULL, owner_acquired_at IS NULL, owner_heartbeat_at IS NULL
FROM cdc_consumer_list('lake')
WHERE consumer_name = 'leased';
----
true	true	true

query III
SELECT action, consumer_name, consumer_id FROM __ducklake_metadata_lake.__ducklake_cdc.__ducklake_cdc_audit
WHERE action = 'consumer_force_release'
ORDER BY audit_id;
----
consumer_force_release	leased	6

statement error
SELECT * FROM cdc_consumer_force_release('lake', 'missing');
----
consumer 'missing' does not exist

# Call-time compatibility re-check: this fake attached database has the
# exact metadata shape the compat check reads, but reports an unsupported
# catalog format. The function must fail before creating any CDC tables.
statement ok
ATTACH ':memory:' AS fake;

statement ok
CREATE SCHEMA fake.__ducklake_metadata_fake;

statement ok
CREATE TABLE fake.__ducklake_metadata_fake.ducklake_metadata (key VARCHAR, value VARCHAR);

statement ok
INSERT INTO fake.__ducklake_metadata_fake.ducklake_metadata VALUES ('version', '99.99');

statement error
SELECT * FROM cdc_consumer_create('fake', 'shouldfail');
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_consumer_reset('fake', 'shouldfail');
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_consumer_drop('fake', 'shouldfail');
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_consumer_force_release('fake', 'shouldfail');
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_consumer_heartbeat('fake', 'shouldfail');
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_window('fake', 'shouldfail');
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_commit('fake', 'shouldfail', 0);
----
CDC_INCOMPATIBLE_CATALOG

statement error
SELECT * FROM cdc_wait('fake', 'shouldfail', timeout_ms = 0);
----
CDC_INCOMPATIBLE_CATALOG

statement ok
ATTACH 'ducklake:__TEST_DIR__/consumer_state_ddl.ducklake' AS ddl_lake (DATA_PATH '__TEST_DIR__/consumer_state_ddl_data');

statement ok
SELECT * FROM cdc_consumer_create('ddl_lake', 'ddl_consumer');

statement ok
CREATE SCHEMA ddl_lake.ddl_s;

query IIII
SELECT event_kind, object_kind, schema_name, object_name FROM cdc_ddl('ddl_lake', 'ddl_consumer');
----
created	schema	ddl_s	ddl_s

statement ok
SET VARIABLE ddl_end_snapshot = (SELECT end_snapshot FROM cdc_window('ddl_lake', 'ddl_consumer'));

statement ok
SELECT * FROM cdc_commit('ddl_lake', 'ddl_consumer', getvariable('ddl_end_snapshot'));

statement ok
CREATE TABLE ddl_lake.ddl_s.ddl_t(id INTEGER);

query IIII
SELECT event_kind, object_kind, schema_name, object_name FROM cdc_ddl('ddl_lake', 'ddl_consumer');
----
created	table	ddl_s	ddl_t

statement ok
SET VARIABLE ddl_end_snapshot = (SELECT end_snapshot FROM cdc_window('ddl_lake', 'ddl_consumer'));

statement ok
SELECT * FROM cdc_commit('ddl_lake', 'ddl_consumer', getvariable('ddl_end_snapshot'));

statement ok
CREATE VIEW ddl_lake.ddl_s.ddl_v AS SELECT * FROM ddl_lake.ddl_s.ddl_t;

query IIII
SELECT event_kind, object_kind, schema_name, object_name FROM cdc_ddl('ddl_lake', 'ddl_consumer');
----
created	view	ddl_s	ddl_v

statement ok
SET VARIABLE ddl_end_snapshot = (SELECT end_snapshot FROM cdc_window('ddl_lake', 'ddl_consumer'));

statement ok
SELECT * FROM cdc_commit('ddl_lake', 'ddl_consumer', getvariable('ddl_end_snapshot'));

statement ok
DROP VIEW ddl_lake.ddl_s.ddl_v;

query IIII
SELECT event_kind, object_kind, schema_name, object_name FROM cdc_ddl('ddl_lake', 'ddl_consumer');
----
dropped	view	ddl_s	ddl_v

statement ok
SET VARIABLE ddl_end_snapshot = (SELECT end_snapshot FROM cdc_window('ddl_lake', 'ddl_consumer'));

statement ok
SELECT * FROM cdc_commit('ddl_lake', 'ddl_consumer', getvariable('ddl_end_snapshot'));

statement ok
DROP TABLE ddl_lake.ddl_s.ddl_t;

query IIII
SELECT event_kind, object_kind, schema_name, object_name FROM cdc_ddl('ddl_lake', 'ddl_consumer');
----
dropped	table	ddl_s	ddl_t

statement ok
SET VARIABLE ddl_end_snapshot = (SELECT end_snapshot FROM cdc_window('ddl_lake', 'ddl_consumer'));

statement ok
SELECT * FROM cdc_commit('ddl_lake', 'ddl_consumer', getvariable('ddl_end_snapshot'));

statement ok
DROP SCHEMA ddl_lake.ddl_s;

query IIII
SELECT event_kind, object_kind, schema_name, object_name FROM cdc_ddl('ddl_lake', 'ddl_consumer');
----
dropped	schema	ddl_s	ddl_s

statement error
SELECT * FROM cdc_ddl('fake', 'shouldfail');
----
CDC_INCOMPATIBLE_CATALOG
