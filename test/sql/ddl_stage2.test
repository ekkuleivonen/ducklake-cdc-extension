# name: test/sql/ddl_stage2.test
# description: Stage-2 cdc_ddl details payloads (column lists, column-level
# group: [sql]

#              diffs, view definitions, Finding-1 rename detection) plus the
#              cdc_schema_diff sugar that projects per-column rows from the
#              same extractor.

require ducklake_cdc

require icu

require parquet

# DuckLake is loaded at runtime from the official extension repository
# instead of being compiled from source. `require ducklake` cannot be used
# because sqllogictest's `require <ext>` only checks for statically-loaded
# extensions, which DuckLake is not in this build.
statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl2.ducklake' AS lake (DATA_PATH '__TEST_DIR__/ddl2_data');

statement ok
CREATE TABLE lake.orders(id INTEGER, status VARCHAR DEFAULT 'new');

# created.table now ships the column list in details. DuckLake stores
# types as lowercase strings (`int32`, `varchar`) and the DEFAULT clause as
# the raw value with no surrounding quotes (`new`, not `'new'`). DuckLake
# v1.5.1's pinned DuckLake tuple stores an absent default as the literal
# string `NULL`. column_id and column_order both start at 1 in DuckLake catalogs.
query I
SELECT details FROM cdc_recent_ddl('lake', for_table = 'orders')
WHERE event_kind = 'created' AND object_kind = 'table';
----
{"columns":[{"id":1,"order":1,"name":"id","type":"int32","nullable":true,"default":"NULL"},{"id":2,"order":2,"name":"status","type":"varchar","nullable":true,"default":"new"}]}

# ALTER TABLE ADD COLUMN c3
statement ok
ALTER TABLE lake.orders ADD COLUMN c3 BIGINT;

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake', for_table = 'orders')
WHERE event_kind = 'altered'
ORDER BY snapshot_id;
----
altered	{"added":[{"id":3,"name":"c3","type":"int64","nullable":true,"default":"NULL"}]}

# ALTER TABLE DROP COLUMN c3
statement ok
ALTER TABLE lake.orders DROP COLUMN c3;

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake', for_table = 'orders')
WHERE event_kind = 'altered'
ORDER BY snapshot_id;
----
altered	{"added":[{"id":3,"name":"c3","type":"int64","nullable":true,"default":"NULL"}]}
altered	{"dropped":[{"id":3,"name":"c3","type":"int64","nullable":true,"default":"NULL"}]}

# ALTER TABLE RENAME COLUMN status TO state
statement ok
ALTER TABLE lake.orders RENAME COLUMN status TO state;

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake', for_table = 'orders')
WHERE event_kind = 'altered'
ORDER BY snapshot_id;
----
altered	{"added":[{"id":3,"name":"c3","type":"int64","nullable":true,"default":"NULL"}]}
altered	{"dropped":[{"id":3,"name":"c3","type":"int64","nullable":true,"default":"NULL"}]}
altered	{"renamed":[{"id":2,"old_name":"status","new_name":"state"}]}

# ALTER TABLE ALTER COLUMN id TYPE BIGINT
statement ok
ALTER TABLE lake.orders ALTER COLUMN id TYPE BIGINT;

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake', for_table = 'orders')
WHERE event_kind = 'altered'
ORDER BY snapshot_id;
----
altered	{"added":[{"id":3,"name":"c3","type":"int64","nullable":true,"default":"NULL"}]}
altered	{"dropped":[{"id":3,"name":"c3","type":"int64","nullable":true,"default":"NULL"}]}
altered	{"renamed":[{"id":2,"old_name":"status","new_name":"state"}]}
altered	{"type_changed":[{"id":1,"name":"id","old_type":"int32","new_type":"int64"}]}

# ALTER TABLE RENAME (Finding-1: surfaced as altered.table with old/new
# table names rather than as a paired drop+create).
statement ok
ALTER TABLE lake.orders RENAME TO orders_v2;

# After a rename the for_table filter must use the new name (it works
# against the post-event qualified name in the row, which is the contract).
query II
SELECT event_kind, details FROM cdc_recent_ddl('lake', for_table = 'orders_v2')
WHERE event_kind = 'altered'
ORDER BY snapshot_id DESC
LIMIT 1;
----
altered	{"old_table_name":"orders","new_table_name":"orders_v2"}

# created.view ships the definition + dialect + column_aliases.
statement ok
CREATE VIEW lake.orders_v AS SELECT id, state FROM lake.main.orders_v2;

query I
SELECT details FROM cdc_recent_ddl('lake', for_table = 'orders_v2')
WHERE object_kind = 'view' AND event_kind = 'created';
----

# (No row above because for_table filters by table identity, not view.
# Without the filter, the view's details should be present. column_aliases
# is the empty string when the user did not specify aliases - DuckLake
# stores empty-string for "no aliases", not NULL.)
query II
SELECT object_kind, details FROM cdc_recent_ddl('lake')
WHERE event_kind = 'created' AND object_kind = 'view'
ORDER BY snapshot_id;
----
view	{"definition":"SELECT id, state FROM lake.main.orders_v2","dialect":"duckdb","column_aliases":""}

# cdc_schema_diff: per-column rows over the diff between two snapshots.
# Range covers everything from snapshot 0 up through current. We expect:
#   - 3 added rows (id and status from CREATE TABLE, plus c3 from ADD COLUMN)
#   - 1 dropped row (c3 from DROP COLUMN)
#   - 1 renamed row (status -> state)
#   - 1 type_changed row (id INTEGER -> BIGINT)
query II
SELECT change_kind, count(*) FROM cdc_schema_diff('lake', 'orders_v2', 0, 99999)
GROUP BY change_kind
ORDER BY change_kind;
----
added	3
dropped	1
renamed	1
table_rename	1
type_changed	1

# A specific column-level row carries old/new fields populated for the
# dimension that changed.
query IIII
SELECT change_kind, column_id, old_type, new_type FROM cdc_schema_diff('lake', 'orders_v2', 0, 99999)
WHERE change_kind = 'type_changed';
----
type_changed	1	int32	int64

# Negative / inverted range is rejected at bind.
statement error
SELECT * FROM cdc_schema_diff('lake', 'orders', 5, 1);
----
invalid snapshot range

# -----------------------------------------------------------------------------
# Per ADR 0008 + roadmap "cdc_ddl excludes compacted_table". Maintenance
# events emitted by `ducklake_merge_adjacent_files` show up in
# `cdc_events` (the raw stream) but NOT in `cdc_ddl` (typed DDL surface).
# Operators monitoring compactions read `cdc_events`; sinks consuming
# typed DDL never see them.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/compaction.ducklake' AS lake_cp (DATA_PATH '__TEST_DIR__/compaction_data');

statement ok
CREATE TABLE lake_cp.orders(id INTEGER);

statement ok
INSERT INTO lake_cp.orders VALUES (1);

statement ok
INSERT INTO lake_cp.orders VALUES (2);

statement ok
INSERT INTO lake_cp.orders VALUES (3);

statement ok
CALL ducklake_merge_adjacent_files('lake_cp');

# Stage-1 cdc_ddl scan sees only created/altered/dropped tokens; it
# does NOT classify `compacted_table:<id>` / `merge_adjacent:<id>` as
# DDL. The CREATE TABLE event still surfaces; the compaction does not.
query II
SELECT event_kind, object_kind FROM cdc_recent_ddl('lake_cp', for_table = 'orders')
ORDER BY snapshot_id, object_kind;
----
created	table

# -----------------------------------------------------------------------------
# Per ADR 0008 + roadmap: within a single snapshot, DDL rows are
# delivered in stable (object_kind, object_id) order. The asymmetry is
# intentional — for `created` events, schemas come before the views/
# tables they contain; for `dropped` events, the order is reversed
# (children before parents) so that downstream identity tracking can
# observe the live row before it disappears.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl_order.ducklake' AS lake_or (DATA_PATH '__TEST_DIR__/ddl_order_data');

statement ok
BEGIN TRANSACTION;

statement ok
CREATE SCHEMA lake_or.warehouse;

statement ok
CREATE TABLE lake_or.warehouse.events(id INTEGER);

statement ok
COMMIT;

# Within the snapshot, the schema must appear before the table it
# contains (created.schema rank=0 < created.table rank=1). Restrict to
# the user-created snapshot — `main` was created at lake init and
# would otherwise pad the projection.
query II
SELECT event_kind, object_kind FROM cdc_recent_ddl('lake_or')
WHERE event_kind = 'created' AND object_kind IN ('schema', 'table')
  AND object_name IN ('warehouse', 'events');
----
created	schema
created	table

# -----------------------------------------------------------------------------
# Phase 2 deferral 3: nested-column diff parent/child reordering.
# DuckLake stores nested struct fields as separate `ducklake_column` rows
# whose `parent_column` references the struct's column_id. The Phase 1
# implementation lost this relationship in the `altered.table.details`
# payload and in `cdc_schema_diff` rows. Phase 2 surfaces the parent
# reference as `parent_column_id` on every nested-field row and stable-
# sorts the diff so parents precede children on ADD and children precede
# parents on DROP — the same depth-ordering rule cdc_ddl already uses
# for top-level (object_kind, object_id) within a snapshot.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl_nested.ducklake' AS lake_n (DATA_PATH '__TEST_DIR__/ddl_nested_data');

statement ok
CREATE TABLE lake_n.orders(id INTEGER, customer STRUCT(name VARCHAR, tier VARCHAR), amount INTEGER);

# `created.table.details.columns` includes `parent_column_id` for nested
# fields and emits parents ahead of children. Naming is `parent_column_id`
# (not `parent_column`) per ADR 0008, aligning the JSON key with both the
# `cdc_schema_diff` column name and the doc reference.
query I
SELECT details FROM cdc_recent_ddl('lake_n', for_table => 'orders')
WHERE event_kind = 'created' AND object_kind = 'table';
----
{"columns":[{"id":1,"order":1,"name":"id","type":"int32","nullable":true,"default":"NULL"},{"id":2,"order":2,"name":"customer","type":"struct","nullable":true,"default":"NULL"},{"id":3,"order":3,"name":"name","type":"varchar","nullable":true,"default":"NULL","parent_column_id":2},{"id":4,"order":4,"name":"tier","type":"varchar","nullable":true,"default":"NULL","parent_column_id":2},{"id":5,"order":5,"name":"amount","type":"int32","nullable":true,"default":"NULL"}]}

# `cdc_schema_diff` exposes parent_column_id as a typed column rather than
# embedding it inside a JSON blob. Pure-create surfaces emit one `added`
# row per column; the parent column appears before its children (depth
# ascending) and children carry the parent id.
query III
SELECT change_kind, column_id, parent_column_id FROM cdc_schema_diff('lake_n', 'orders', 0, 99999)
ORDER BY snapshot_id, column_id;
----
added	1	NULL
added	2	NULL
added	3	2
added	4	2
added	5	NULL

# ALTER TABLE ADD COLUMN nested.field — DuckDB syntax for adding a
# struct field. The field shows up in `details.added` with
# `parent_column_id` set to the struct's column_id (here 2).
statement ok
ALTER TABLE lake_n.orders ADD COLUMN customer.region VARCHAR;

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake_n', for_table => 'orders')
WHERE event_kind = 'altered'
ORDER BY snapshot_id DESC LIMIT 1;
----
altered	{"added":[{"id":6,"name":"region","type":"varchar","nullable":false,"default":"NULL","parent_column_id":2}]}

# Cross-product stress test: rename, type-change, and nested-field add
# in one transaction. Phase 2 § 'DDL-event exhaustive tests' requires
# the single `altered.table` payload to populate all three of
# `{old_table_name,new_table_name}`, `type_changed`, and `added` (with
# correct `parent_column_id`) simultaneously. Migrations doing this
# combination are common; getting any one of the three wrong silently is
# the failure mode this test exists to prevent.
#
# Phase 2 follow-up #1 (dedup): the rename snapshot now emits exactly
# one `altered.table` row — Stage-1 processes `tables_created` before
# `tables_altered` within a snapshot via the SQL ORDER BY in
# `ExtractDdlRows`, so the Finding-1 path registers (snapshot_id,
# table_id) and the sibling `tables_altered:<table_id>` row is dropped.
# Phase 2 follow-up #2: `LookupTableById` is now snapshot-bound, so the
# row carries the post-rename name `orders_v2` everywhere it's needed.
statement ok
BEGIN TRANSACTION;

statement ok
ALTER TABLE lake_n.orders RENAME TO orders_v2;

statement ok
ALTER TABLE lake_n.orders_v2 ALTER COLUMN amount SET DATA TYPE BIGINT;

statement ok
ALTER TABLE lake_n.orders_v2 ADD COLUMN customer.country VARCHAR;

statement ok
COMMIT;

# Exactly one altered row at the cross-product snapshot now (was two
# pre-dedup). Phase 2 follow-up #1.
query I
SELECT count(*) FROM cdc_recent_ddl('lake_n', for_table => 'orders_v2')
WHERE event_kind = 'altered'
  AND snapshot_id = (SELECT max(snapshot_id) FROM lake_n.snapshots());
----
1

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake_n', for_table => 'orders_v2')
WHERE event_kind = 'altered' AND object_name = 'orders_v2'
ORDER BY snapshot_id DESC LIMIT 1;
----
altered	{"old_table_name":"orders","new_table_name":"orders_v2","added":[{"id":7,"name":"country","type":"varchar","nullable":false,"default":"NULL","parent_column_id":2}],"type_changed":[{"id":5,"name":"amount","old_type":"int32","new_type":"int64"}]}

# DROPPED ordering: when a struct column is dropped, its child fields
# disappear with it. The diff JSON emits children before the parent
# (depth descending) so a downstream consumer tearing down a typed
# schema sees the leaves vanish before the root. Phase 2 follow-up #2:
# this event resolves the table by id and `LookupTableById` is now
# snapshot-bound, so `object_name` is the post-rename `orders_v2` (was
# stuck on the original `orders` pre-fix because of an unbounded
# `LIMIT 1` lookup).
statement ok
ALTER TABLE lake_n.orders_v2 DROP COLUMN customer;

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake_n', for_table => 'orders_v2')
WHERE event_kind = 'altered' AND object_name = 'orders_v2'
ORDER BY snapshot_id DESC LIMIT 1;
----
altered	{"dropped":[{"id":3,"name":"name","type":"varchar","nullable":true,"default":"NULL","parent_column_id":2},{"id":4,"name":"tier","type":"varchar","nullable":true,"default":"NULL","parent_column_id":2},{"id":6,"name":"region","type":"varchar","nullable":false,"default":"NULL","parent_column_id":2},{"id":7,"name":"country","type":"varchar","nullable":false,"default":"NULL","parent_column_id":2},{"id":2,"name":"customer","type":"struct","nullable":true,"default":"NULL"}]}

# -----------------------------------------------------------------------------
# Phase 2 deferral 2: Stage-2 perf shortcut. `BuildAlteredTableDetails`
# and `cdc_schema_diff` skip the two `LookupTableColumnsAt` calls + the
# `DiffColumns` traversal whenever `ducklake_schema_versions` shows no
# per-table schema bump for the snapshot — the diff would be empty by
# construction.
#
# Empirically, every Stage-1-relevant `altered_table:<id>` token under
# DuckDB 1.5.x / DuckLake 4.x is accompanied by a `ducklake_schema_versions`
# row at that snapshot (RENAME TABLE bumps schema_version even though
# the column list is unchanged; ADD/DROP/RENAME/TYPE do too; compaction
# does NOT bump schema_version but is not Stage-1-relevant). So in
# practice the shortcut is *defensively correct* rather than a measurable
# perf win on this DuckLake version — the assertion this test enforces
# is behavioural equivalence: every ALTER path produces the same JSON
# payload regardless of which branch the shortcut takes.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl_perf.ducklake' AS lake_p (DATA_PATH '__TEST_DIR__/ddl_perf_data');

statement ok
CREATE TABLE lake_p.orders(id INTEGER, name VARCHAR);

# Pure RENAME: rename payload is correctly emitted; the column-diff
# part of the JSON stays absent because the column list is unchanged
# (DuckLake's `ducklake_column` row count for table_id 1 is the same
# at snapshot N-1 and snapshot N).
statement ok
ALTER TABLE lake_p.orders RENAME TO orders_v2;

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake_p', for_table => 'orders_v2')
WHERE event_kind = 'altered' AND object_name = 'orders_v2'
ORDER BY snapshot_id DESC LIMIT 1;
----
altered	{"old_table_name":"orders","new_table_name":"orders_v2"}

# A real ALTER (column list change) bumps schema_version → the shortcut
# predicate `TableSchemaVersionBumpedAt = true` holds → diff is computed
# and serialised. Phase 2 follow-up #2: the ADD COLUMN event resolves
# the table by id and `LookupTableById` is now snapshot-bound, so the
# row carries the post-rename `orders_v2` (pre-fix it was stuck on the
# original `orders`).
statement ok
ALTER TABLE lake_p.orders_v2 ADD COLUMN extra BIGINT;

query I
SELECT count(*) FROM __ducklake_metadata_lake_p.ducklake_schema_versions
WHERE table_id = (SELECT table_id FROM __ducklake_metadata_lake_p.ducklake_table WHERE table_name = 'orders_v2')
  AND begin_snapshot = (SELECT max(snapshot_id) FROM __ducklake_metadata_lake_p.ducklake_snapshot);
----
1

query II
SELECT event_kind, details FROM cdc_recent_ddl('lake_p', for_table => 'orders_v2')
WHERE event_kind = 'altered' AND object_name = 'orders_v2'
ORDER BY snapshot_id DESC LIMIT 1;
----
altered	{"added":[{"id":3,"name":"extra","type":"int64","nullable":true,"default":"NULL"}]}

# cdc_schema_diff exercises the same shortcut on its per-snapshot loop.
# Run it across the full window so the shortcut is hit at least once
# per ALTER snapshot in `target_ids`. We assert: the per-column diff
# rows are emitted as expected, and the rename row is emitted exactly
# once. Three `added` rows = the two columns from CREATE TABLE plus the
# one ADD COLUMN. The rename row comes from the Finding-1 path; per-
# column rows for the rename snapshot are zero because the column list
# is unchanged at that snapshot (the perf shortcut path).
query II
SELECT change_kind, count(*) FROM cdc_schema_diff('lake_p', 'orders_v2', 0, 99999)
GROUP BY change_kind
ORDER BY change_kind;
----
added	3
table_rename	1

# -----------------------------------------------------------------------------
# Phase 2 deferral 1: Stage-1 source switched from the comma-separated text
# form (`__ducklake_metadata_<lake>.ducklake_snapshot_changes.changes_made`)
# to the typed MAP form (`<lake>.snapshots().changes`). cdc_ddl,
# cdc_recent_ddl, and cdc_schema_diff all consume the new source; the text
# form stays alive for cdc_events (its surface still emits `changes_made`
# verbatim) and for ChangesTouchConsumerTables (consumer-filter eval).
#
# The upstream probe in test/upstream/output/ confirms all three DuckLake
# backends (DuckDB, SQLite, Postgres) emit identical MAP key sets for
# every DDL kind, so the MAP-driven dispatcher is backend-agnostic by
# construction. Per ADR 0008.
#
# This block exercises every Stage-1-relevant MAP key in one lake so a
# regression in the MAP unnest path or the per-key dispatcher would
# fail loudly here. The existing suite (ddl_stage2.test from line 30
# onwards, sugar.test, recent_sugar.test, ddl_order block above) is
# the broader regression coverage — it asserts byte-exact JSON
# payloads for every DDL kind under both Stage-1 sources.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl_map.ducklake' AS lake_m (DATA_PATH '__TEST_DIR__/ddl_map_data');

statement ok
CREATE SCHEMA lake_m.warehouse;

statement ok
CREATE TABLE lake_m.warehouse.events(id INTEGER, kind VARCHAR);

statement ok
ALTER TABLE lake_m.warehouse.events ADD COLUMN amount BIGINT;

statement ok
CREATE VIEW lake_m.warehouse.recent AS SELECT * FROM lake_m.warehouse.events;

statement ok
DROP VIEW lake_m.warehouse.recent;

statement ok
DROP TABLE lake_m.warehouse.events;

statement ok
DROP SCHEMA lake_m.warehouse;

# All seven Stage-1 MAP keys exercised above (schemas_created x2 [main +
# warehouse], tables_created, tables_altered, views_created, views_dropped,
# tables_dropped, schemas_dropped) must surface as the seven typed cdc_ddl
# events. We assert the (event_kind, object_kind) tuples in snapshot order;
# the implicit `main` schema created at lake init is suppressed via
# event_kind+object_kind+object_name filter.
query III
SELECT event_kind, object_kind, object_name FROM cdc_recent_ddl('lake_m')
WHERE NOT (event_kind = 'created' AND object_kind = 'schema' AND object_name = 'main')
ORDER BY snapshot_id, object_kind, event_kind;
----
created	schema	warehouse
created	table	events
altered	table	events
created	view	recent
dropped	view	recent
dropped	table	events
dropped	schema	warehouse

# Direct probe of the Stage-1 source: the MAP form returns one (key, list)
# row per DDL kind per snapshot. All keys observed across the test must
# come from the documented Stage-1 set. Phase 0 upstream probe + ADR 0008.
query I
SELECT DISTINCT e.key
FROM lake_m.snapshots() s, UNNEST(map_entries(s.changes)) AS u(e)
ORDER BY e.key;
----
schemas_created
schemas_dropped
tables_altered
tables_created
tables_dropped
views_created
views_dropped

# -----------------------------------------------------------------------------
# Phase 2 follow-ups #1 (dedup) and #2 (snapshot-bound LookupTableById):
# fold the two pre-existing Stage-1 extraction artefacts surfaced during
# deferral 3 into the typed surface contract.
#
# Pre-fix: a transaction combining `RENAME TABLE` with column-list
# changes emitted *two* `altered.table` rows for the same (snapshot_id,
# table_id) — one via the Finding-1 rename path with the post-rename
# name and the rename payload, one via the `tables_altered:<id>` path
# with the *original* name (because `LookupTableById` had no snapshot
# bound) and the column-only details. Downstream consumers keying on
# `(snapshot_id, object_kind, object_id)` would see the table twice.
#
# Post-fix: the Stage-1 dispatcher orders `tables_created` map keys
# before `tables_altered` within a snapshot, registers Finding-1
# promotions in a per-snapshot set, and skips the matching ID-resolved
# row. `LookupTableById` (and the Schema/View siblings) now use the
# same `(begin_snapshot <= snap AND (end_snapshot IS NULL OR
# end_snapshot > snap))` predicate `LookupTableColumnsAt` already uses
# — DROPPED events pass `snapshot_id - 1` to hit the row alive
# immediately before the drop.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl_followups.ducklake' AS lake_f (DATA_PATH '__TEST_DIR__/ddl_followups_data');

statement ok
CREATE TABLE lake_f.orders(id INTEGER, name VARCHAR, amount INTEGER);

# Cross-product in one transaction: rename + add column + type change.
# Pre-dedup this snapshot would emit two altered.table rows for the
# same table_id; post-dedup exactly one survives (the Finding-1 row,
# which carries the strictly larger payload).
statement ok
BEGIN TRANSACTION;

statement ok
ALTER TABLE lake_f.orders RENAME TO orders_v2;

statement ok
ALTER TABLE lake_f.orders_v2 ADD COLUMN region VARCHAR;

statement ok
ALTER TABLE lake_f.orders_v2 ALTER COLUMN amount SET DATA TYPE BIGINT;

statement ok
COMMIT;

# Exactly one altered.table row per (snapshot_id, object_id) — that's
# the Phase 2 follow-up #1 contract.
query I
SELECT count(*) FROM cdc_recent_ddl('lake_f')
WHERE event_kind = 'altered' AND object_kind = 'table'
  AND snapshot_id = (SELECT max(snapshot_id) FROM lake_f.snapshots());
----
1

# The surviving row is the Finding-1 row: it carries old/new names AND
# the column diff. (Phase 2 follow-up #1 dropped the smaller sibling.)
query II
SELECT object_name, details FROM cdc_recent_ddl('lake_f')
WHERE event_kind = 'altered' AND object_kind = 'table'
  AND snapshot_id = (SELECT max(snapshot_id) FROM lake_f.snapshots());
----
orders_v2	{"old_table_name":"orders","new_table_name":"orders_v2","added":[{"id":4,"name":"region","type":"varchar","nullable":true,"default":"NULL"}],"type_changed":[{"id":3,"name":"amount","old_type":"int32","new_type":"int64"}]}

# Pure ALTER (no rename) at a later snapshot exercises the
# tables_altered branch on its own. Phase 2 follow-up #2: the row's
# object_name reflects the table's name as-of this snapshot
# (`orders_v2`), not whatever name the storage layer happened to
# return first.
statement ok
ALTER TABLE lake_f.orders_v2 ADD COLUMN status VARCHAR;

query III
SELECT event_kind, object_name, details FROM cdc_recent_ddl('lake_f')
WHERE event_kind = 'altered' AND object_kind = 'table'
ORDER BY snapshot_id DESC LIMIT 1;
----
altered	orders_v2	{"added":[{"id":5,"name":"status","type":"varchar","nullable":true,"default":"NULL"}]}

# DROP after rename: Phase 2 follow-up #2 makes `LookupTableById` pass
# `snapshot_id - 1` so the dropped row carries the immediately-before-
# drop name (`orders_v2`), not the original name.
statement ok
DROP TABLE lake_f.orders_v2;

query III
SELECT event_kind, object_kind, object_name FROM cdc_recent_ddl('lake_f')
WHERE event_kind = 'dropped' AND object_kind = 'table'
ORDER BY snapshot_id DESC LIMIT 1;
----
dropped	table	orders_v2

# cdc_schema_diff exercises the same dedup on its per-snapshot loop:
# one table_rename row at the cross-product snapshot (not two), and the
# per-column diff rows are not duplicated. Total: 3 added (3 from
# CREATE TABLE) + 1 added (region from cross-product) + 1 type_changed
# (amount) + 1 added (status from later ALTER) + 1 table_rename = 5
# added, 1 type_changed, 1 table_rename. (DROP TABLE doesn't surface
# in cdc_schema_diff because target_ids is bounded to live rows.)
query II
SELECT change_kind, count(*) FROM cdc_schema_diff('lake_f', 'orders_v2', 0, 99999)
GROUP BY change_kind
ORDER BY change_kind;
----
added	5
table_rename	1
type_changed	1
