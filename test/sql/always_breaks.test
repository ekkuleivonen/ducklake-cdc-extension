# name: test/sql/always_breaks.test
# description: "Always breaks" coverage for edge cases that repeatedly regress.
# group: [sql]

#              Runs against the embedded DuckDB catalog and uses only shipped
#              Phase-1 primitives + sugar.

require ducklake_cdc

require icu

require parquet

# DuckLake is loaded at runtime from the official extension repository
# instead of being compiled from source. `require ducklake` cannot be used
# because sqllogictest's `require <ext>` only checks for statically-loaded
# extensions, which DuckLake is not in this build.
statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

# -----------------------------------------------------------------------------
# Inlined-data path. DuckLake's DATA_INLINING_ROW_LIMIT controls when small
# row batches stay inlined in the catalog vs flushed to a parquet file. Both
# paths must surface through cdc_events / cdc_changes; the underlying
# table_changes API handles the read transparently and we must not regress on
# the seamless behaviour. We force inlined writes by setting a small limit at
# attach time.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/inlined.ducklake' AS lake_inline (DATA_PATH '__TEST_DIR__/inlined_data', DATA_INLINING_ROW_LIMIT 100);

statement ok
CREATE TABLE lake_inline.orders(id INTEGER, status VARCHAR);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_inline',
  'inline_consumer',
  start_at = '1',
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := 'dml', change_type := '*')
  ]
);

statement ok
INSERT INTO lake_inline.orders VALUES (1, 'new'), (2, 'paid');

# cdc_events surfaces the inlined snapshot — the changes_made token will be
# `inlined_insert:<id>` per the snapshots()-changes-MAP reference table. We
# don't pin to a specific token format; the assertion is "the snapshot was
# discovered" (count >= 1) and "cdc_changes returns the rows that landed".
query I
SELECT count(*) >= 1 FROM cdc_events('lake_inline', 'inline_consumer');
----
true

query II
SELECT count(*), count(DISTINCT change_type) FROM cdc_changes('lake_inline', 'inline_consumer', 'orders');
----
2	1

# Mixed inlined + materialised in one window: keep inserting until DuckLake
# flushes (we generated 2 rows above; add a larger batch in a separate
# snapshot). cdc_changes returns rows from both snapshots seamlessly.
statement ok
INSERT INTO lake_inline.orders SELECT i, 'paid' FROM range(3, 203) t(i);

query I
SELECT count(*) FROM cdc_changes('lake_inline', 'inline_consumer', 'orders');
----
202

# -----------------------------------------------------------------------------
# All four change types pass through unfiltered. Insert / update / delete a
# row; the default consumer (change_types := NULL) sees four events:
# insert, update_preimage, update_postimage, delete. No implicit
# update_preimage filtering — that's the project's contract.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/four_kinds.ducklake' AS lake4 (DATA_PATH '__TEST_DIR__/four_kinds_data');

statement ok
CREATE TABLE lake4.events(id INTEGER, status VARCHAR);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake4',
  'all_kinds',
  start_at = '1',
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := 'dml', change_type := '*')
  ]
);

statement ok
INSERT INTO lake4.events VALUES (1, 'created');

statement ok
UPDATE lake4.events SET status = 'shipped' WHERE id = 1;

statement ok
DELETE FROM lake4.events WHERE id = 1;

query II
SELECT count(*), count(DISTINCT change_type) FROM cdc_changes('lake4', 'all_kinds', 'events');
----
4	4

# A single-change-type filter (e.g. ['delete']) sees exactly one event.
statement ok
SELECT * FROM cdc_consumer_create(
  'lake4',
  'deletes_only',
  start_at = '1',
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := 'dml', change_type := 'delete')
  ]
);

query II
SELECT count(*), count(DISTINCT change_type) FROM cdc_changes('lake4', 'deletes_only', 'events');
----
1	1

# -----------------------------------------------------------------------------
# Schema change mid-window with stop_at_schema_change=true (default). The
# first window bounds before the ALTER (schema_changes_pending=true). The
# consumer reads DML for the OLD schema, commits, and the next window starts
# AT the ALTER snapshot. cdc_ddl returns the altered.table event for that
# window; cdc_changes returns DML under the NEW schema only.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/schema_default.ducklake' AS lake_sd (DATA_PATH '__TEST_DIR__/schema_default_data');

statement ok
CREATE TABLE lake_sd.orders(id INTEGER);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_sd',
  'sd_consumer',
  start_at = '1',
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := '*', change_type := '*')
  ]
);

statement ok
INSERT INTO lake_sd.orders VALUES (1), (2);

statement ok
ALTER TABLE lake_sd.orders ADD COLUMN region VARCHAR DEFAULT 'UNKNOWN';

statement ok
INSERT INTO lake_sd.orders VALUES (3, 'EU');

# First window is bounded before the ALTER; schema_changes_pending=true.
query II
SELECT has_changes, schema_changes_pending FROM cdc_window('lake_sd', 'sd_consumer');
----
true	true

# All DML rows from this window are under the OLD schema (no `region` column,
# 1 column projection works).
query I
SELECT count(*) FROM cdc_changes('lake_sd', 'sd_consumer', 'orders');
----
2

# Commit and advance.
statement ok
SET VARIABLE end_snap_v1 = (SELECT end_snapshot FROM cdc_window('lake_sd', 'sd_consumer'));

statement ok
SELECT * FROM cdc_commit('lake_sd', 'sd_consumer', getvariable('end_snap_v1'));

# Second window: starts AT the ALTER snapshot. cdc_ddl returns the
# altered.table event; cdc_changes returns the EU insert under the new schema.
query II
SELECT event_kind, object_kind FROM cdc_ddl('lake_sd', 'sd_consumer')
WHERE object_kind = 'table'
ORDER BY snapshot_id;
----
altered	table

query I
SELECT count(*) FROM cdc_changes('lake_sd', 'sd_consumer', 'orders') WHERE change_type = 'insert';
----
1

# -----------------------------------------------------------------------------
# Schema change with stop_at_schema_change=false. Same workload, but the
# consumer opts out of schema bounding. cdc_window returns one window
# spanning both schema versions. cdc_ddl returns the altered.table event;
# cdc_changes returns rows from BOTH schemas in one batch (rows reconciled
# to end-snapshot schema by DuckLake).
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/schema_optout.ducklake' AS lake_so (DATA_PATH '__TEST_DIR__/schema_optout_data');

statement ok
CREATE TABLE lake_so.orders(id INTEGER);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_so',
  'so_consumer',
  start_at = '1',
  stop_at_schema_change = false,
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := '*', change_type := '*')
  ]
);

statement ok
INSERT INTO lake_so.orders VALUES (1), (2);

statement ok
ALTER TABLE lake_so.orders ADD COLUMN region VARCHAR DEFAULT 'UNKNOWN';

statement ok
INSERT INTO lake_so.orders VALUES (3, 'EU');

# Window spans both schemas. schema_changes_pending=true is informational.
query I
SELECT has_changes FROM cdc_window('lake_so', 'so_consumer');
----
true

# cdc_ddl includes the altered.table event INSIDE this window.
query II
SELECT event_kind, object_kind FROM cdc_ddl('lake_so', 'so_consumer')
WHERE object_kind = 'table'
ORDER BY snapshot_id;
----
altered	table

# cdc_changes returns rows from BOTH schemas. The end-snapshot reconciliation
# means every row carries the `region` column; pre-ALTER rows get NULL or
# the DEFAULT depending on DuckLake's behaviour.
query I
SELECT count(*) FROM cdc_changes('lake_so', 'so_consumer', 'orders') WHERE change_type = 'insert';
----
3

# -----------------------------------------------------------------------------
# DDL+DML in one snapshot, ordering enforced. ALTER TABLE + INSERT in one
# transaction. With stop_at_schema_change=false, both cdc_ddl and
# cdc_changes return events for the same snapshot id; the per-snapshot
# delivery contract guarantees DDL events are ordered first inside that
# snapshot (ADR 0008). The extension-level assertion: cdc_ddl events appear
# WITH THE SAME snapshot_id as the cdc_changes events.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/ddl_dml.ducklake' AS lake_dd (DATA_PATH '__TEST_DIR__/ddl_dml_data');

statement ok
CREATE TABLE lake_dd.orders(id INTEGER);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_dd',
  'dd_consumer',
  start_at = '1',
  stop_at_schema_change = false,
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := '*', change_type := '*')
  ]
);

statement ok
INSERT INTO lake_dd.orders VALUES (1);

# Multi-statement transaction: DDL + DML committed together.
statement ok
BEGIN TRANSACTION;

statement ok
ALTER TABLE lake_dd.orders ADD COLUMN region VARCHAR DEFAULT 'UNKNOWN';

statement ok
INSERT INTO lake_dd.orders VALUES (2, 'EU');

statement ok
COMMIT;

# The DDL event and the DML rows live in the same snapshot id. Asserts the
# end-to-end claim: a single snapshot can carry both kinds and the consumer
# sees them under the same snapshot_id (the binding library is responsible
# for in-snapshot DDL-before-DML interleaving). Materialize the two stateful
# CDC calls separately so DuckLake does not try to commit two catalog updates
# inside one SELECT.
statement ok
CREATE TEMP TABLE dd_ddl_snapshot AS
SELECT max(snapshot_id) AS snapshot_id
FROM cdc_ddl('lake_dd', 'dd_consumer')
WHERE event_kind = 'altered';

statement ok
CREATE TEMP TABLE dd_dml_snapshot AS
SELECT max(snapshot_id) AS snapshot_id
FROM cdc_changes('lake_dd', 'dd_consumer', 'orders')
WHERE change_type = 'insert' AND id = 2;

query I
SELECT dd_ddl_snapshot.snapshot_id = dd_dml_snapshot.snapshot_id
FROM dd_ddl_snapshot, dd_dml_snapshot;
----
true

# -----------------------------------------------------------------------------
# Column-drop audit limitation, documented behaviour. ALTER TABLE DROP
# COLUMN + DELETE in one snapshot. cdc_changes returns the deletes WITHOUT
# the dropped column's value. We assert this is what happens (so we don't
# silently regress) and link to docs/operational/audit-limitations.md.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/drop_audit.ducklake' AS lake_da (DATA_PATH '__TEST_DIR__/drop_audit_data');

statement ok
CREATE TABLE lake_da.orders(id INTEGER, customer_email VARCHAR);

statement ok
INSERT INTO lake_da.orders VALUES (1, 'a@example.com'), (2, 'b@example.com');

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_da',
  'da_consumer',
  start_at = '2',
  stop_at_schema_change = false,
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := 'dml', change_type := '*')
  ]
);

statement ok
BEGIN TRANSACTION;

statement ok
ALTER TABLE lake_da.orders DROP COLUMN customer_email;

statement ok
DELETE FROM lake_da.orders WHERE id = 1;

statement ok
COMMIT;

# After the drop: cdc_changes returns the delete event but customer_email is
# gone from the row shape entirely (table_changes reads at the END snapshot
# schema). Assertion: the column does NOT appear in the row.
query I
SELECT count(column_name) FROM (
  SELECT * FROM cdc_changes('lake_da', 'da_consumer', 'orders') LIMIT 0
)
JOIN duckdb_columns()
  ON  database_name = 'duckdb'
  AND column_name = 'customer_email';
----
0

# -----------------------------------------------------------------------------
# `commit_message` / `commit_extra_info` set via set_commit_message propagate
# end-to-end through cdc_events and cdc_changes. The extension surfaces
# these so consumers can dispatch on commit_extra_info (the outbox pattern).
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/commit_meta.ducklake' AS lake_cm (DATA_PATH '__TEST_DIR__/commit_meta_data');

statement ok
CREATE TABLE lake_cm.orders(id INTEGER);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_cm',
  'cm_consumer',
  start_at = '1',
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := 'dml', change_type := '*')
  ]
);

statement ok
BEGIN TRANSACTION;

statement ok
CALL lake_cm.set_commit_message('tests', 'order placed', extra_info => '{"event":"OrderPlaced"}');

statement ok
INSERT INTO lake_cm.orders VALUES (1);

statement ok
COMMIT;

# cdc_events surfaces author / commit_message / commit_extra_info.
query III
SELECT author, commit_message, commit_extra_info FROM cdc_events('lake_cm', 'cm_consumer')
ORDER BY snapshot_id DESC LIMIT 1;
----
tests	order placed	{"event":"OrderPlaced"}

# cdc_changes surfaces the same fields appended to every change row.
query III
SELECT author, commit_message, commit_extra_info FROM cdc_changes('lake_cm', 'cm_consumer', 'orders')
ORDER BY snapshot_id DESC LIMIT 1;
----
tests	order placed	{"event":"OrderPlaced"}

# -----------------------------------------------------------------------------
# Multi-consumer: two consumers on the same lake advance independently. Each
# has its own owner_token lease and last_committed_snapshot. Read by one
# does not move the cursor of the other.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/multi.ducklake' AS lake_mc (DATA_PATH '__TEST_DIR__/multi_data');

statement ok
CREATE TABLE lake_mc.orders(id INTEGER);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_mc',
  'consumer_a',
  start_at = '1',
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := 'dml', change_type := '*')
  ]
);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_mc',
  'consumer_b',
  start_at = '1',
  subscriptions := [
    struct_pack(scope_kind := 'catalog', schema_name := NULL::VARCHAR, table_name := NULL::VARCHAR,
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := 'dml', change_type := '*')
  ]
);

statement ok
INSERT INTO lake_mc.orders VALUES (1), (2), (3);

# Both consumers see the same window before any commits.
query II
SELECT consumer_name, last_committed_snapshot FROM cdc_consumer_stats('lake_mc')
WHERE consumer_name IN ('consumer_a', 'consumer_b')
ORDER BY consumer_name;
----
consumer_a	1
consumer_b	1

# consumer_a advances; consumer_b stays put.
statement ok
SET VARIABLE end_snap_a = (SELECT end_snapshot FROM cdc_window('lake_mc', 'consumer_a'));

statement ok
SELECT * FROM cdc_commit('lake_mc', 'consumer_a', getvariable('end_snap_a'));

query II
SELECT consumer_name, last_committed_snapshot > 1 FROM cdc_consumer_stats('lake_mc')
WHERE consumer_name IN ('consumer_a', 'consumer_b')
ORDER BY consumer_name;
----
consumer_a	true
consumer_b	false

# -----------------------------------------------------------------------------
# Dropped-table policy. Consumer with an identity table subscription continues
# to advance after DROP TABLE; cdc_consumer_stats() counts the dropped
# subscription. This is the contract — we DO NOT halt the consumer.
# Operators monitor stats and act on dropped subscriptions themselves.
# -----------------------------------------------------------------------------

statement ok
ATTACH 'ducklake:__TEST_DIR__/dropped.ducklake' AS lake_dr (DATA_PATH '__TEST_DIR__/dropped_data');

statement ok
CREATE TABLE lake_dr.orders(id INTEGER);

statement ok
INSERT INTO lake_dr.orders VALUES (1);

statement ok
SELECT * FROM cdc_consumer_create(
  'lake_dr',
  'dr_consumer',
  start_at = '2',
  stop_at_schema_change = false,
  subscriptions := [
    struct_pack(scope_kind := 'table', schema_name := 'main', table_name := 'orders',
                schema_id := NULL::BIGINT, table_id := NULL::BIGINT,
                event_category := '*', change_type := '*')
  ]
);

statement ok
DROP TABLE lake_dr.orders;

# The dropped table is surfaced as a dropped subscription.
query II
SELECT consumer_name, subscriptions_dropped FROM cdc_consumer_stats('lake_dr', consumer => 'dr_consumer');
----
dr_consumer	5

# cdc_window keeps advancing — the consumer is NOT halted by the drop. The
# next call to cdc_window succeeds; cdc_ddl returns the dropped.table event.
query II
SELECT event_kind, object_kind FROM cdc_ddl('lake_dr', 'dr_consumer')
WHERE event_kind = 'dropped' AND object_kind = 'table';
----
dropped	table
